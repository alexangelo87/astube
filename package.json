{
  "name": "astube",
  "version": "1.0.0",
  "description": "YouTube downloader desktop app",
  "main": "out/main/index.js",
  "author": "asTube",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "package": "npm run icons && npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "^41.2.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "yt-dlp-wrap": "^2.3.12"
  },
  "build": {
    "appId": "com.astube.app",
    "productName": "asTube",
    "icon": "resources/icon",
    "mac": {
      "category": "public.app-category.video",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      { "from": "resources/icon.png", "to": "icon.png" }
    ]
  }
}
